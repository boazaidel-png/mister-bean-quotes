    }
    *{box-sizing:border-box;font-family:Arial,"Helvetica Neue",sans-serif}body{margin:0;background:var(--bg);color:var(--text)}
    header{background:linear-gradient(135deg,#4a2f22,#23120c);color:white;padding:22px 22px;position:sticky;top:0;z-index:20;box-shadow:var(--shadow)}
    header .top{max-width:1500px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
    h1{margin:0;font-size:25px}.sub{margin-top:5px;color:#eadfd8;font-size:14px}.pill{background:#ffffff18;border:1px solid #ffffff30;border-radius:999px;padding:7px 12px;font-size:13px}
    main{max-width:1500px;margin:0 auto;padding:18px}.grid{display:grid;grid-template-columns:1.15fr .85fr;gap:16px}.grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:16px;box-shadow:var(--shadow);margin-bottom:16px}.card h2{margin:0 0 14px;color:var(--brown);font-size:19px}.card h3{margin:16px 0 9px;color:var(--brown2);font-size:16px}
    label{display:block;color:var(--muted);font-size:13px;margin-bottom:5px}input,select,textarea{width:100%;border:1px solid var(--line);border-radius:12px;padding:10px;background:white;font-size:15px;color:var(--text)}input:focus,select:focus,textarea:focus{outline:2px solid #6b463230;border-color:var(--brown2)}.field{margin-bottom:11px}
    button{border:0;border-radius:12px;background:var(--brown);color:#fff;padding:10px 14px;font-weight:700;font-size:14px;cursor:pointer}button:hover{filter:brightness(.96)}button.secondary{background:#eadfd6;color:var(--brown)}button.danger{background:var(--red)}button.blue{background:var(--blue)}button.small{padding:7px 9px;border-radius:9px;font-size:12px}.actions{display:flex;gap:9px;flex-wrap:wrap}.actions button{width:auto}.muted{color:var(--muted)}
    .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.metric{background:var(--cream);border:1px solid var(--line);border-radius:15px;padding:13px}.metric .t{font-size:12px;color:var(--muted);margin-bottom:5px}.metric .v{font-size:20px;font-weight:800;color:var(--brown)}.metric .s{font-size:12px;color:var(--muted);margin-top:4px}.pos{color:var(--green)!important;font-weight:800}.neg{color:var(--red)!important;font-weight:800}.warn{color:var(--amber)!important;font-weight:800}
    .tablewrap{overflow:auto;border:1px solid var(--line);border-radius:14px}table{border-collapse:collapse;width:100%;min-width:980px;background:white}th,td{border-bottom:1px solid var(--line);padding:9px;text-align:right;vertical-align:middle;white-space:nowrap}th{background:var(--cream);color:var(--brown);font-size:13px}td{font-size:14px}tr:last-child td{border-bottom:0}td input,td select{min-width:120px;padding:8px;border-radius:9px}.notice{background:#fff7dd;border:1px solid #ebd08c;color:#664400;border-radius:14px;padding:12px;font-size:14px;margin-top:10px;line-height:1.45}.okbox{background:#ecfdf3;border-color:#b7e4c7;color:#14532d}.badbox{background:#fff1f0;border-color:#ffccc7;color:#7f1d1d}
    .saved{max-height:320px;overflow:auto;border:1px solid var(--line);border-radius:14px;background:white}.savedItem{padding:12px;border-bottom:1px solid var(--line);cursor:pointer}.savedItem:hover{background:var(--cream)}.savedItem:last-child{border-bottom:0}.rowTitle{font-weight:800;color:var(--brown)}.tiny{font-size:12px;color:var(--muted);margin-top:3px}.kbd{direction:ltr;unicode-bidi:embed;background:#f2ece6;border-radius:7px;padding:2px 6px;display:inline-block}.hide{display:none!important}
    .scenarioGood{background:#f4fff7}.scenarioBad{background:#fff7f7}.scenarioMid{background:#fffaf0}
    @media(max-width:950px){header{position:static}.grid,.grid2,.grid3,.grid4,.metrics{grid-template-columns:1fr}.actions button{width:100%}main{padding:12px}table{min-width:1050px}h1{font-size:21px}}
  </style>
