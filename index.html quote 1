<body>
<header><div class="top"><div><h1>מיסטר בין - מערכת הצעות מחיר</h1><div class="sub">לקוחות משרדיים | חישוב רווחיות, ציוד, בלנדים, שכירות ומינימום צריכה</div></div><div class="pill" id="connectionStatus">Firebase: מתחבר...</div></div></header>
<main>
  <div class="grid">
    <section class="card">
      <h2>1. פרטי לקוח וצריכה</h2>
      <div class="grid3">
        <div class="field"><label>שם לקוח</label><input id="clientName" placeholder="לדוגמה: Monday" /></div>
        <div class="field"><label>שם / מספר גרסה</label><input id="quoteVersion" value="גרסה 1" /></div>
        <div class="field"><label>סטטוס</label><select id="quoteStatus"><option>טיוטה</option><option>בבדיקה</option><option>נשלחה</option><option>אושרה</option><option>נדחתה</option></select></div>
        <div class="field"><label>דירוג לקוח</label><select id="clientRank"><option>רגיל</option><option>מעניין</option><option>אסטרטגי</option></select></div>
        <div class="field"><label>מספר עובדים</label><input id="employees" type="number" value="100" min="0" step="1" /></div>
        <div class="field"><label>צריכה קיימת בפועל בק״ג</label><input id="actualKg" type="number" value="0" min="0" step="0.1" /></div>
        <div class="field"><label>כוסות לעובד ביום</label><input id="cupsPerEmployee" type="number" value="1.5" min="0" step="0.1" /></div>
        <div class="field"><label>ימי עבודה בחודש</label><input id="workDaysMonth" type="number" value="21" min="0" step="1" /></div>
        <div class="field"><label>גרם קפה לכוס</label><input id="gramsPerCup" type="number" value="12" min="0" step="1" /></div>
        <div class="field"><label>ימי עבודה בשבוע</label><input id="workDaysWeek" type="number" value="5" min="0" step="1" /></div>
        <div class="field"><label>התחייבות חוזית בחודשים</label><input id="contractMonths" type="number" value="36" min="0" step="1" /></div>
        <div class="field"><label>עיגול מינימום צריכה כלפי מעלה</label><input id="roundToKg" type="number" value="5" min="1" step="1" /></div>
      </div>
      <div class="actions"><button onclick="calculateAll()">חשב מחדש</button><button class="secondary" onclick="newQuote()">נקה לטופס חדש</button></div>
    </section>
    <section class="card">
      <h2>שמירה וטעינת הצעות</h2>
      <div class="actions"><button onclick="saveQuote()">שמור הצעה</button><button class="secondary" onclick="loadQuotes()">רענן רשימה</button><button class="blue" onclick="duplicateQuote()">שכפל כגרסה חדשה</button></div>
      <div class="notice" id="saveStatus">לא נשמר עדיין.</div>
      <h3>הצעות שמורות</h3><div class="saved" id="savedQuotes"><div class="savedItem muted">טוען...</div></div>
    </section>
  </div>

  <section class="card"><h2>2. צריכה ופוטנציאל</h2><div class="metrics" id="consumptionMetrics"></div><div class="notice" id="consumptionNote"></div></section>

  <section class="card">
    <h2>3. בלנדים וכמויות</h2>
    <div class="tablewrap"><table><thead><tr><th>בלנד</th><th>כמות חודשית</th><th>עלות לק״ג</th><th>מחיר מכירה</th><th>מינימום</th><th>ק״ג במחיר מלא</th><th>ק״ג בהנחה</th><th>מחיר אפקטיבי</th><th>הכנסה</th><th>רווח</th><th></th></tr></thead><tbody id="blendRows"></tbody></table></div>
    <div class="actions" style="margin-top:12px"><button class="secondary" onclick="addBlendRow()">הוסף בלנד</button><button class="secondary" onclick="fillBlendByRecommended()">מלא לפי הצריכה המומלצת</button><button class="secondary" onclick="fillBlendByActual()">מלא לפי הצריכה בפועל</button></div>
    <div class="notice">ברירת מחדל: עלות + 40 ₪ לק״ג. רצפה: עלות + 10 ₪. מעל 100 ק״ג: 10% הנחה רק על הקילוגרמים שמעל 100, בחלוקה יחסית בין הבלנדים.</div>
  </section>

  <section class="card">
    <h2>4. ציוד וסט לקוח</h2>
    <div class="grid4">
      <div class="field"><label>פריסת תשלום ליבואן</label><input id="supplierMonths" type="number" value="8" min="1" step="1" /></div>
      <div class="field"><label>שכירות ידנית חודשית</label><input id="manualLease" type="number" value="0" min="0" step="1" /></div>
      <div class="field"><label>עלויות חודשיות נוספות</label><input id="extraMonthlyCost" type="number" value="0" min="0" step="1" /></div>
      <div class="field"><label>רווח במכירת ציוד ללקוח (%)</label><input id="equipmentSaleMargin" type="number" value="15" min="0" step="1" /></div>
    </div>
    <div class="tablewrap"><table><thead><tr><th>פריט</th><th>כמות</th><th>עלות יחידה</th><th>תפוקה יומית</th><th>עלות כוללת</th><th></th></tr></thead><tbody id="equipmentRows"></tbody></table></div>
    <div class="actions" style="margin-top:12px"><button class="secondary" onclick="addEquipmentRow()">הוסף ציוד</button><button class="secondary" onclick="addInstallRow()">הוסף התקנה</button></div>
  </section>

  <section class="card"><h2>5. תפוקה ומכונות</h2><div class="metrics" id="machineMetrics"></div><div class="notice" id="machineNote"></div></section>

  <section class="card">
    <h2>6. השוואת מתווים</h2>
    <div class="tablewrap"><table><thead><tr><th>מתווה</th><th>הכנסה חודשית</th><th>עלות חודשית בפריסה</th><th>רווח חודשי בפריסה</th><th>רווח אחרי הפריסה</th><th>חודשים להחזר ציוד</th><th>מינימום צריכה לאיזון בפריסה</th><th>הערה</th></tr></thead><tbody id="scenarioRows"></tbody></table></div>
  </section>

  <section class="card"><h2>7. סיכום מספרים</h2><div class="metrics" id="summaryMetrics"></div><div class="notice" id="summaryNote"></div></section>
</main>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-app.js";
import { getFirestore, collection, addDoc, getDocs, doc, getDoc, setDoc, deleteDoc, query, orderBy, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore.js";

const firebaseConfig={apiKey:"AIzaSyAQtBPnAfDJnN4ewYu6C7mseWfhRp3S1_c",authDomain:"mister-bean-quotes.firebaseapp.com",projectId:"mister-bean-quotes",storageBucket:"mister-bean-quotes.firebasestorage.app",messagingSenderId:"182356242822",appId:"1:182356242822:web:0ee286d0496f20dc62bc07",measurementId:"G-FW92S0GWZM"};
let db=null,currentId=null;
try{const app=initializeApp(firebaseConfig);db=getFirestore(app);document.getElementById('connectionStatus').textContent='Firebase: מחובר';}catch(e){document.getElementById('connectionStatus').textContent='Firebase: שגיאה';console.error(e)}

const BLENDS=[{name:'EMERALD',ratio:'50/50',cost:50},{name:'DX',ratio:'70/30',cost:60},{name:'HB+',ratio:'92/8',cost:70},{name:'TUSCANINI',ratio:'100%',cost:70},{name:'PEGANINI',ratio:'20/80',cost:70},{name:'STRADIVARI',ratio:'100%',cost:90}];
const EQUIP=[{name:'DR. COFFEE C-12',cost:3350,cap:70,type:'machine'},{name:'DR. COFFEE F-15',cost:4090,cap:100,type:'machine'},{name:'DR. COFFEE - COFFEE BREAK',cost:5350,cap:100,type:'machine'},{name:'Emilio mini',cost:800,cap:30,type:'machine'},{name:'Emilio MAX',cost:1090,cap:30,type:'machine'},{name:'מקציף חלב',cost:129,cap:0,type:'addon'},{name:'מקרר חלב',cost:591,cap:0,type:'addon'},{name:'פילטר בריטה',cost:350,cap:0,type:'addon'},{name:'אוסמוזה',cost:550,cap:0,type:'addon'},{name:'התקנה',cost:300,cap:0,type:'install'},{name:'עלות נוספת ידנית',cost:0,cap:0,type:'manual'}];
const $=id=>document.getElementById(id);const n=id=>Number($(id)?.value||0);const money=x=>(Number(x)||0).toLocaleString('he-IL',{maximumFractionDigits:0})+' ₪';const kg=x=>(Number(x)||0).toLocaleString('he-IL',{maximumFractionDigits:1})+' ק״ג';const pct=x=>(Number(x)||0).toLocaleString('he-IL',{maximumFractionDigits:1})+'%';const roundUp=(v,to)=>Math.ceil((Number(v)||0)/(Number(to)||1))*(Number(to)||1);
function esc(s){return String(s??'').replace(/[&<>'"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[m]))}
function metric(t,v,s='',cls=''){return `<div class="metric"><div class="t">${t}</div><div class="v ${cls}">${v}</div>${s?`<div class="s">${s}</div>`:''}</div>`}
function blendOptions(sel){return BLENDS.map(b=>`<option value="${esc(b.name)}" ${b.name===sel?'selected':''}>${esc(b.name)} (${b.ratio})</option>`).join('')}
function equipOptions(sel){return EQUIP.map(e=>`<option value="${esc(e.name)}" ${e.name===sel?'selected':''}>${esc(e.name)}</option>`).join('')}
function getBlend(name){return BLENDS.find(b=>b.name===name)||BLENDS[0]}function getEquip(name){return EQUIP.find(e=>e.name===name)||EQUIP[0]}

window.addBlendRow=function(data={}){const b=getBlend(data.name||'DX');const tr=document.createElement('tr');tr.className='blendRow';tr.innerHTML=`<td><select class="blendName">${blendOptions(b.name)}</select></td><td><input class="blendQty" type="number" min="0" step="0.1" value="${data.qty??0}"></td><td class="blendCost">${money(b.cost)}</td><td><input class="blendPrice" type="number" min="0" step="1" value="${data.price??b.cost+40}"></td><td class="blendMin">${money(b.cost+10)}</td><td class="fullKg">0</td><td class="discKg">0</td><td class="effPrice">0</td><td class="blendRevenue">0</td><td class="blendProfit">0</td><td><button class="danger small removeBlend" type="button">מחק</button></td>`;$('blendRows').appendChild(tr);wireRow(tr);calculateAll()}
window.addEquipmentRow=function(data={}){const e=getEquip(data.name||'DR. COFFEE F-15');const tr=document.createElement('tr');tr.className='equipRow';tr.innerHTML=`<td><select class="equipName">${equipOptions(e.name)}</select></td><td><input class="equipQty" type="number" min="0" step="1" value="${data.qty??1}"></td><td><input class="equipCost" type="number" min="0" step="1" value="${data.cost??e.cost}"></td><td class="equipCap">${e.cap}</td><td class="equipTotal">0</td><td><button class="danger small removeEquip" type="button">מחק</button></td>`;$('equipmentRows').appendChild(tr);wireRow(tr);calculateAll()}
window.addInstallRow=function(){addEquipmentRow({name:'התקנה',qty:1,cost:300})}
function wireRow(scope=document){scope.querySelectorAll('input,select').forEach(el=>{el.oninput=calculateAll;el.onchange=()=>{if(el.classList.contains('blendName')){const b=getBlend(el.value);const tr=el.closest('tr');tr.querySelector('.blendPrice').value=b.cost+40}if(el.classList.contains('equipName')){const e=getEquip(el.value);const tr=el.closest('tr');tr.querySelector('.equipCost').value=e.cost;tr.querySelector('.equipCap').textContent=e.cap}calculateAll()}});scope.querySelectorAll('.removeBlend').forEach(b=>b.onclick=()=>{b.closest('tr').remove();calculateAll()});scope.querySelectorAll('.removeEquip').forEach(b=>b.onclick=()=>{b.closest('tr').remove();calculateAll()})}
function readBlends(){return [...document.querySelectorAll('.blendRow')].map(tr=>{const b=getBlend(tr.querySelector('.blendName').value);return {name:b.name,ratio:b.ratio,cost:b.cost,qty:Number(tr.querySelector('.blendQty').value)||0,price:Math.max(Number(tr.querySelector('.blendPrice').value)||0,b.cost+10),min:b.cost+10,tr}})}
function readEquip(){return [...document.querySelectorAll('.equipRow')].map(tr=>{const e=getEquip(tr.querySelector('.equipName').value);const qty=Number(tr.querySelector('.equipQty').value)||0;const cost=Number(tr.querySelector('.equipCost').value)||0;return {name:e.name,type:e.type,qty,cost,cap:e.cap,total:qty*cost,tr}})}
function calcConsumption(){const employees=n('employees'),cupsEmp=n('cupsPerEmployee'),days=n('workDaysMonth'),grams=n('gramsPerCup'),actual=n('actualKg');const cupsDay=employees*cupsEmp;const recKg=cupsDay*days*grams/1000;const actualCupsDay=actual>0&&grams>0&&days>0?(actual*1000/grams/days):0;const gapKg=recKg-actual;const gapPct=recKg>0?gapKg/recKg*100:0;return{employees,cupsDay,recKg,actual,actualCupsDay,gapKg,gapPct,grams,days}}
function calcBlends(){const rows=readBlends();const totalKg=rows.reduce((s,r)=>s+r.qty,0);const discountedKg=Math.max(0,totalKg-100);let revenue=0,cost=0,profit=0,weightedGrossPerKg=0;rows.forEach(r=>{const share=totalKg>0?r.qty/totalKg:0;const disc=r.qty>0?discountedKg*share:0;const full=Math.max(0,r.qty-disc);const discountedPrice=Math.max(r.price*.9,r.min);const rev=full*r.price+disc*discountedPrice;const c=r.qty*r.cost;const p=rev-c;const eff=r.qty>0?rev/r.qty:0;revenue+=rev;cost+=c;profit+=p;r.tr.querySelector('.blendCost').textContent=money(r.cost);r.tr.querySelector('.blendMin').textContent=money(r.min);r.tr.querySelector('.fullKg').textContent=kg(full);r.tr.querySelector('.discKg').textContent=kg(disc);r.tr.querySelector('.effPrice').textContent=money(eff);r.tr.querySelector('.blendRevenue').textContent=money(rev);r.tr.querySelector('.blendProfit').innerHTML=`<span class="${p>=0?'pos':'neg'}">${money(p)}</span>`});weightedGrossPerKg=totalKg>0?profit/totalKg:0;return{rows,totalKg,discountedKg,revenue,cost,profit,avgPrice:totalKg?revenue/totalKg:0,avgCost:totalKg?cost/totalKg:0,grossPerKg:weightedGrossPerKg}}
function calcEquip(){const rows=readEquip();let total=0,cap=0,machines=0;rows.forEach(r=>{total+=r.total;if(r.type==='machine'){cap+=r.qty*r.cap;machines+=r.qty}r.tr.querySelector('.equipCap').textContent=r.cap;r.tr.querySelector('.equipTotal').textContent=money(r.total)});return{rows,total,cap,machines}}
function bestMachine(cupsDay){const machines=EQUIP.filter(e=>e.type==='machine').sort((a,b)=>a.cap-b.cap||a.cost-b.cost);let options=machines.map(m=>({m,count:Math.ceil(cupsDay/m.cap),cost:Math.ceil(cupsDay/m.cap)*m.cost}));options=options.filter(o=>isFinite(o.count)&&o.count>0);if(!options.length)return null;let fitting=options.filter(o=>o.count===1&&o.m.cap>=cupsDay);if(fitting.length){fitting.sort((a,b)=>a.m.cap-b.m.cap||a.cost-b.cost);return fitting[0]}options.sort((a,b)=>a.count-b.count||a.cost-b.cost);const f15=options.find(o=>o.m.name==='DR. COFFEE F-15'),cb=options.find(o=>o.m.name==='DR. COFFEE - COFFEE BREAK');if(f15&&cb&&f15.count===cb.count)return f15;return options[0]}
function scenario(name, lease, equipSale=false){const C=calcBlends(),E=calcEquip();const supplierMonths=Math.max(1,n('supplierMonths'));const extra=n('extraMonthlyCost');const monthlyEquip= equipSale?0:E.total/supplierMonths;const saleMargin=n('equipmentSaleMargin')/100;const oneTimeProfit=equipSale?E.total*saleMargin:0;const monthlyIncome=C.revenue+lease;const costDuring=C.cost+monthlyEquip+extra;const profitDuring=monthlyIncome-costDuring;const profitAfter=C.revenue+lease-C.cost-extra;const monthlyContributionAfter=C.profit+lease-extra;const payback=monthlyContributionAfter>0?E.total/monthlyContributionAfter:Infinity;const grossPerKg=C.totalKg?C.profit/C.totalKg:0;const fixedDuring=monthlyEquip+extra-lease;let minKg=0;if(grossPerKg>0){minKg=roundUp(Math.max(0,fixedDuring/grossPerKg),n('roundToKg'))}let note=equipSale?`רווח חד פעמי ממכירת ציוד: ${money(oneTimeProfit)}`:lease>0?`שכירות חודשית: ${money(lease)}`:'הכנסה מקפה בלבד';return{name,monthlyIncome,costDuring,profitDuring,profitAfter,payback,minKg,note,oneTimeProfit}}
function calcScenarios(){const E=calcEquip();return[scenario('מכונות ללא עלות',0),scenario('שכירות נמוכה /36',E.total/36),scenario('שכירות מומלצת /24',E.total/24),scenario('שכירות מהירה /12',E.total/12),scenario('שכירות ידנית',n('manualLease')),scenario('רכישת ציוד על ידי הלקוח',0,true)]}
window.calculateAll=function(){const con=calcConsumption(),C=calcBlends(),E=calcEquip();$('consumptionMetrics').innerHTML=metric('צריכה מומלצת',kg(con.recKg),'לפי עובדים × כוסות × ימים × גרם')+metric('צריכה בפועל',kg(con.actual),'לפי הזנה ידנית')+metric('פער / פוטנציאל',kg(con.gapKg),pct(con.gapPct),con.gapKg>=0?'pos':'warn')+metric('כוסות ביום',Math.round(con.cupsDay).toLocaleString('he-IL'),'לפי עובדים')+metric('כוסות ביום בפועל',Math.round(con.actualCupsDay).toLocaleString('he-IL'),'לפי צריכה קיימת')+metric('סה״כ בלנדים',kg(C.totalKg),'הכמות שעליה מתבסס החישוב')+metric('מחיר ממוצע',money(C.avgPrice),'אחרי הנחות')+metric('רווח ממוצע לק״ג',money(C.grossPerKg),'אחרי עלות קפה',C.grossPerKg>=10?'pos':'neg');$('consumptionNote').innerHTML=con.actual>0?`הצריכה בפועל ${con.actual<con.recKg?'נמוכה':'גבוהה'} מהצריכה המומלצת ב-${kg(Math.abs(con.gapKg))}.`:'לא הוזנה צריכה בפועל. ניתן להשתמש בצריכה המומלצת או למלא ידנית בבלנדים.';
const avgCups=E.machines>0?con.cupsDay/E.machines:0;const capStatus=E.cap>=con.cupsDay?'pos':'neg';$('machineMetrics').innerHTML=metric('עלות סט ציוד',money(E.total),'כולל התקנה ותוספות')+metric('תשלום חודשי ליבואן',money(E.total/Math.max(1,n('supplierMonths'))),`${n('supplierMonths')} חודשים`)+metric('סה״כ תפוקה יומית',Math.round(E.cap).toLocaleString('he-IL')+' כוסות','לפי הציוד שבחרת',capStatus)+metric('ממוצע כוסות למכונה',Math.round(avgCups).toLocaleString('he-IL'),`${E.machines} מכונות`);
const bm=bestMachine(con.cupsDay);$('machineNote').className='notice '+(E.cap>=con.cupsDay?'okbox':'badbox');$('machineNote').innerHTML=bm?`לפי ${Math.round(con.cupsDay)} כוסות ביום, חישוב תפוקה פשוט מציע בערך ${bm.count} × ${bm.m.name}. הציוד שבחרת ${E.cap>=con.cupsDay?'עומד':'לא עומד'} בתפוקה לפי הנתונים.`:'אין מספיק נתוני כוסות כדי להמליץ על מכונה.';
const scenarios=calcScenarios();$('scenarioRows').innerHTML=scenarios.map(s=>{const cls=s.profitDuring<0?'scenarioBad':s.profitDuring<500?'scenarioMid':'scenarioGood';return `<tr class="${cls}"><td>${s.name}</td><td>${money(s.monthlyIncome)}</td><td>${money(s.costDuring)}</td><td><span class="${s.profitDuring>=0?'pos':'neg'}">${money(s.profitDuring)}</span></td><td><span class="${s.profitAfter>=0?'pos':'neg'}">${money(s.profitAfter)}</span></td><td>${isFinite(s.payback)?s.payback.toFixed(1):'לא חוזר'}</td><td>${kg(s.minKg)}</td><td>${s.note}</td></tr>`}).join('');
$('summaryMetrics').innerHTML=metric('הכנסה חודשית מקפה',money(C.revenue),kg(C.totalKg))+metric('עלות קפה חודשית',money(C.cost),'לפני מע״מ')+metric('רווח קפה חודשי',money(C.profit),'לפני ציוד ועלויות נוספות',C.profit>=0?'pos':'neg')+metric('עלות ציוד כוללת',money(E.total),'סט לקוח')+metric('מכירת ציוד ללקוח',money(E.total*(1+n('equipmentSaleMargin')/100)),`עלות + ${n('equipmentSaleMargin')}%`)+metric('שכירות /24',money(E.total/24),'דיפולט מומלץ')+metric('שכירות /36',money(E.total/36),'נמוכה')+metric('שכירות /12',money(E.total/12),'מהירה');
$('summaryNote').innerHTML=`החישוב מציג נתונים בלבד. אין החלטת מערכת. אם רווח בתקופת הפריסה שלילי, שים לב למינימום צריכה, שכירות ציוד או שינוי מחיר לק״ג.`}
window.fillBlendByRecommended=function(){const con=calcConsumption();const row=document.querySelector('.blendRow')||addBlendRow();document.querySelector('.blendRow .blendQty').value=con.recKg.toFixed(1);calculateAll()}
window.fillBlendByActual=function(){const con=calcConsumption();const row=document.querySelector('.blendRow')||addBlendRow();document.querySelector('.blendRow .blendQty').value=con.actual.toFixed(1);calculateAll()}
function getState(){return{clientName:$('clientName').value,quoteVersion:$('quoteVersion').value,quoteStatus:$('quoteStatus').value,clientRank:$('clientRank').value,inputs:{employees:n('employees'),actualKg:n('actualKg'),cupsPerEmployee:n('cupsPerEmployee'),workDaysMonth:n('workDaysMonth'),gramsPerCup:n('gramsPerCup'),workDaysWeek:n('workDaysWeek'),contractMonths:n('contractMonths'),roundToKg:n('roundToKg'),supplierMonths:n('supplierMonths'),manualLease:n('manualLease'),extraMonthlyCost:n('extraMonthlyCost'),equipmentSaleMargin:n('equipmentSaleMargin')},blends:readBlends().map(r=>({name:r.name,qty:r.qty,price:Number(r.tr.querySelector('.blendPrice').value)||r.price})),equipment:readEquip().map(r=>({name:r.name,qty:r.qty,cost:r.cost})),computed:{consumption:calcConsumption(),coffee:calcBlends(),equipment:calcEquip(),scenarios:calcScenarios()}}}
function setVal(id,v){$(id).value=v??$(id).value}function loadState(s){currentId=s.id||currentId;setVal('clientName',s.clientName);setVal('quoteVersion',s.quoteVersion);setVal('quoteStatus',s.quoteStatus);setVal('clientRank',s.clientRank);Object.entries(s.inputs||{}).forEach(([k,v])=>setVal(k,v));$('blendRows').innerHTML='';(s.blends||[]).forEach(addBlendRow);if(!(s.blends||[]).length)addBlendRow({name:'DX',qty:0});$('equipmentRows').innerHTML='';(s.equipment||[]).forEach(addEquipmentRow);if(!(s.equipment||[]).length)addEquipmentRow({name:'DR. COFFEE F-15',qty:1});calculateAll()}
window.saveQuote=async function(){if(!db){$('saveStatus').textContent='אין חיבור ל-Firebase';return}const state=getState();if(!state.clientName.trim()){alert('חסר שם לקוח');return}try{state.updatedAt=serverTimestamp();if(currentId){await setDoc(doc(db,'quotes',currentId),state,{merge:true});$('saveStatus').textContent='ההצעה עודכנה בהצלחה.'}else{state.createdAt=serverTimestamp();const ref=await addDoc(collection(db,'quotes'),state);currentId=ref.id;$('saveStatus').textContent='ההצעה נשמרה בהצלחה.'}await loadQuotes()}catch(e){console.error(e);$('saveStatus').innerHTML='שגיאה בשמירה. בדוק ש-Firestore פעיל ושה-Rules במצב בדיקה.'}}
window.loadQuotes=async function(){if(!db)return;try{const q=query(collection(db,'quotes'),orderBy('updatedAt','desc'));const snap=await getDocs(q);const box=$('savedQuotes');box.innerHTML='';if(snap.empty){box.innerHTML='<div class="savedItem muted">אין הצעות שמורות עדיין.</div>';return}snap.forEach(d=>{const x=d.data();const div=document.createElement('div');div.className='savedItem';div.innerHTML=`<div class="rowTitle">${esc(x.clientName||'ללא שם')} · ${esc(x.quoteVersion||'')}</div><div class="tiny">סטטוס: ${esc(x.quoteStatus||'')} · דירוג: ${esc(x.clientRank||'')}</div>`;div.onclick=async()=>{const full=await getDoc(doc(db,'quotes',d.id));loadState({id:d.id,...full.data()});$('saveStatus').textContent='הצעה נטענה.'};box.appendChild(div)})}catch(e){console.error(e);$('savedQuotes').innerHTML='<div class="savedItem muted">לא ניתן לטעון. בדוק Firestore Rules.</div>'}}
window.duplicateQuote=function(){currentId=null;$('quoteVersion').value=($('quoteVersion').value||'גרסה')+' - עותק';$('saveStatus').textContent='שוכפל מקומית. לחץ שמור כדי ליצור גרסה חדשה.'}
window.newQuote=function(){currentId=null;['clientName'].forEach(id=>$(id).value='');$('quoteVersion').value='גרסה 1';$('quoteStatus').value='טיוטה';$('clientRank').value='רגיל';$('employees').value=100;$('actualKg').value=0;$('cupsPerEmployee').value=1.5;$('workDaysMonth').value=21;$('gramsPerCup').value=12;$('workDaysWeek').value=5;$('contractMonths').value=36;$('roundToKg').value=5;$('supplierMonths').value=8;$('manualLease').value=0;$('extraMonthlyCost').value=0;$('equipmentSaleMargin').value=15;$('blendRows').innerHTML='';addBlendRow({name:'DX',qty:37.8});$('equipmentRows').innerHTML='';addEquipmentRow({name:'DR. COFFEE F-15',qty:1});addInstallRow();$('saveStatus').textContent='טופס חדש.';calculateAll()}

['clientName','quoteVersion','quoteStatus','clientRank','employees','actualKg','cupsPerEmployee','workDaysMonth','gramsPerCup','workDaysWeek','contractMonths','roundToKg','supplierMonths','manualLease','extraMonthlyCost','equipmentSaleMargin'].forEach(id=>$(id).addEventListener('input',calculateAll));
newQuote();loadQuotes();
</script>
